{
    "name": "rs-stock",
    "displayName": "LAXMI AGENCY",
    "private": true,
    "version": "0.1.17",
    "description": "Laxmi Agency management system (local-only)",
    "type": "module",
    "main": "electron.js",
    "homepage": "./",
    "repository": {
        "type": "git",
        "url": ""
    },
    "scripts": {
        "dev": "vite",
        "dev:electron": "cross-env NODE_ENV=development node_modules/electron/dist/electron.exe .",
        "build": "vite build",
        "build:electron": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false ELECTRON_BUILDER_CACHE=.eb-cache electron-builder",
        "icon:generate": "node scripts/generate-icon.mjs",
        "release:local": "npm run icon:generate && npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false ELECTRON_BUILDER_CACHE=.eb-cache electron-builder --win --dir && node scripts/make-local-update.mjs",
        "installer:build": "npm run icon:generate && npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false ELECTRON_BUILDER_CACHE=.eb-cache electron-builder --win",
        "deploy:desktop": "powershell -ExecutionPolicy Bypass -File scripts\\\\deploy-desktop.ps1",
        "preview": "vite preview",
        "test": "vitest --environment jsdom",
        "test:ui": "vitest --ui --environment jsdom"
    },
    "build": {
        "appId": "com.laxmiagency.management",
        "productName": "LAXMI AGENCY",
        "directories": {
            "buildResources": "public",
            "output": "release-dist"
        },
        "files": [
            "dist/**/*",
            "electron.js",
            "preload.js",
            "package.json"
        ],
        "publish": [],
        "win": {
            "icon": "public/icon.ico",
            "target": [
                "nsis",
                "portable"
            ],
            "signAndEditExecutable": false,
            "certificateFile": null,
            "certificatePassword": null,
            "signingHashAlgorithms": [
                "sha256"
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "LAXMI AGENCY"
        },
        "portable": {
            "artifactName": "Laxmi-Agency-${version}.exe"
        }
    },
    "dependencies": {
        "html2canvas": "^1.4.1",
        "jspdf": "^2.5.2",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.0.0",
        "@testing-library/react": "^14.0.0",
        "@vitejs/plugin-react": "^5.1.1",
        "cross-env": "^7.0.0",
        "electron": "^30.0.0",
        "electron-builder": "^24.0.0",
        "jsdom": "^22.0.0",
        "vite": "^4.0.0",
        "vitest": "^1.0.0",
        "png-to-ico": "^2.1.0"
    }
}
